{% extends 'base.html.twig' %}

{% block title %}Edit User Role - MediStock{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-pencil-square"></i> Edit User Role</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <strong>User:</strong> {{ user.email }}<br>
                        <strong>Name:</strong> {{ user.fullName ?? 'N/A' }}
                    </div>

                    {{ form_start(form) }}
                        <div class="mb-3">
                            {{ form_label(form.role, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.role, {'attr': {'class': 'form-select'}}) }}
                            {{ form_errors(form.role) }}
                        </div>

                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i>
                            <strong>Admin:</strong> Full access to all features including analytics, reports, and predictions.<br>
                            <strong>Ground Level:</strong> Can only add drugs and log consumption. Cannot access analytics, reports, or predictions.
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Update Role
                            </button>
                            <a href="{{ path('app_user_index') }}" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}


