{% extends 'base.html.twig' %}

{% block title %}Register - MediStock{% endblock %}

{% block body %}
<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 80vh;">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-capsule" style="font-size: 3rem; color: #667eea;"></i>
                        <h2 class="mt-3 mb-1">Create Account</h2>
                        <p class="text-muted">Join MediStock to manage your inventory</p>
                    </div>

                    {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}
                        <div class="mb-3">
                            {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control form-control-lg'}}) }}
                            {{ form_errors(registrationForm.email) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(registrationForm.fullName, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.fullName, {'attr': {'class': 'form-control form-control-lg'}}) }}
                            {{ form_errors(registrationForm.fullName) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(registrationForm.plainPassword.first, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-control form-control-lg'}}) }}
                            {{ form_errors(registrationForm.plainPassword.first) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(registrationForm.plainPassword.second, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-control form-control-lg'}}) }}
                            {{ form_errors(registrationForm.plainPassword.second) }}
                        </div>

                        <div class="mb-3 p-3 bg-light rounded">
                            <h6 class="mb-3"><i class="bi bi-shield-check"></i> Admin Registration</h6>
                            
                            <div class="mb-3">
                                <div class="form-check">
                                    {{ form_widget(registrationForm.registerAsAdmin, {'attr': {'class': 'form-check-input'}}) }}
                                    {{ form_label(registrationForm.registerAsAdmin, null, {'label_attr': {'class': 'form-check-label'}}) }}
                                </div>
                                <small class="text-muted">Check this if you're the first user or want admin access</small>
                            </div>

                            <div class="mb-0">
                                {{ form_label(registrationForm.adminCode, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(registrationForm.adminCode, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(registrationForm.adminCode) }}
                                <small class="text-muted">Enter "ADMIN2024" to register as admin (or leave empty for regular user)</small>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mb-3">
                            <button class="btn btn-primary btn-lg" type="submit">
                                <i class="bi bi-person-plus"></i> Create Account
                            </button>
                        </div>
                    {{ form_end(registrationForm) }}

                    <div class="text-center">
                        <p class="mb-0">Already have an account? 
                            <a href="{{ path('app_login') }}" class="text-decoration-none">Sign in here</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

