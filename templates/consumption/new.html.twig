{% extends 'base.html.twig' %}

{% block title %}Log Consumption{% endblock %}

{% block body %}
<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-plus-circle"></i> Log Consumption</h1>
        <a href="{{ path('app_consumption_index') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Log
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">New Consumption Entry</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="mb-3">
                            {{ form_label(form.drug) }}
                            {{ form_widget(form.drug) }}
                            {{ form_errors(form.drug) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.quantity) }}
                            {{ form_widget(form.quantity) }}
                            {{ form_errors(form.quantity) }}
                            <small class="form-text text-muted">Stock will be automatically decreased when you save.</small>
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.consumedAt) }}
                            {{ form_widget(form.consumedAt) }}
                            {{ form_errors(form.consumedAt) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.loggedBy) }}
                            {{ form_widget(form.loggedBy) }}
                            {{ form_errors(form.loggedBy) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.notes) }}
                            {{ form_widget(form.notes) }}
                            {{ form_errors(form.notes) }}
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Log Consumption
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

