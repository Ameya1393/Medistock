{% extends 'base.html.twig' %}

{% block title %}Predictions - {{ drug.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-graph-up"></i> Predictions: {{ drug.name }}</h1>
        <div>
            <a href="{{ path('app_prediction_consumption', {'drug_id': drug.id}) }}" class="btn btn-info">
                <i class="bi bi-graph-up-arrow"></i> Consumption Prediction
            </a>
            <a href="{{ path('app_drug_show', {'id': drug.id}) }}" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Drug
            </a>
        </div>
    </div>

    <!-- Stockout Prediction Card -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm {% if stockoutPrediction.isUrgent|default(false) %}border-danger{% elseif stockoutPrediction.isWarning|default(false) %}border-warning{% endif %}">
                <div class="card-header {% if stockoutPrediction.isUrgent|default(false) %}bg-danger{% elseif stockoutPrediction.isWarning|default(false) %}bg-warning{% else %}bg-info{% endif %} text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-exclamation-triangle-fill"></i> Stockout Prediction
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <th class="w-50">Current Stock:</th>
                                    <td>
                                        <span class="badge {% if drug.isLowStock() %}bg-danger{% else %}bg-success{% endif %} fs-6">
                                            {{ drug.stockQuantity }}
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Threshold:</th>
                                    <td><span class="badge bg-secondary">{{ drug.threshold }}</span></td>
                                </tr>
                                <tr>
                                    <th>Will Run Out:</th>
                                    <td>
                                        {% if stockoutPrediction.willRunOut %}
                                            <span class="badge bg-danger">YES</span>
                                        {% else %}
                                            <span class="badge bg-success">NO (90+ days)</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% if stockoutPrediction.daysUntilStockout %}
                                <tr>
                                    <th>Days Until Stockout:</th>
                                    <td>
                                        <span class="badge {% if stockoutPrediction.isUrgent|default(false) %}bg-danger{% elseif stockoutPrediction.isWarning|default(false) %}bg-warning{% else %}bg-info{% endif %} fs-5">
                                            {{ stockoutPrediction.daysUntilStockout }} days
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Estimated Date:</th>
                                    <td><strong>{{ stockoutPrediction.estimatedDate }}</strong></td>
                                </tr>
                                {% endif %}
                                <tr>
                                    <th>Confidence:</th>
                                    <td>
                                        <span class="badge {% if stockoutPrediction.confidence == 'high' %}bg-success{% elseif stockoutPrediction.confidence == 'medium' %}bg-warning{% else %}bg-danger{% endif %}">
                                            {{ stockoutPrediction.confidence|upper }}
                                        </span>
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <div class="alert {% if stockoutPrediction.isUrgent|default(false) %}alert-danger{% elseif stockoutPrediction.isWarning|default(false) %}alert-warning{% else %}alert-info{% endif %}">
                                <h6><i class="bi bi-info-circle"></i> Prediction Message</h6>
                                <p class="mb-0">{{ stockoutPrediction.message }}</p>
                            </div>
                            {% if stockoutPrediction.isUrgent|default(false) or stockoutPrediction.isWarning|default(false) %}
                            <div class="d-grid gap-2">
                                <a href="{{ path('app_stock_update', {'id': drug.id}) }}" class="btn btn-primary">
                                    <i class="bi bi-pencil-square"></i> Update Stock Now
                                </a>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Consumption Prediction Chart -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-graph-up-arrow"></i> Consumption Prediction (Next 14 Days)
                    </h5>
                </div>
                <div class="card-body">
                    <canvas id="consumptionChart" height="80"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Prediction Details Table -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-calendar-check"></i> Daily Predictions</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Predicted Quantity</th>
                                    <th>Confidence</th>
                                    <th>Range</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for prediction in consumptionPredictions %}
                                <tr>
                                    <td>{{ prediction.date }}</td>
                                    <td><span class="badge bg-info fs-6">{{ prediction.predicted }}</span></td>
                                    <td>
                                        <span class="badge {% if prediction.confidence == 'high' %}bg-success{% elseif prediction.confidence == 'medium' %}bg-warning{% else %}bg-danger{% endif %}">
                                            {{ prediction.confidence|upper }}
                                        </span>
                                    </td>
                                    <td>
                                        {% if prediction.upperBound is defined %}
                                            <small class="text-muted">{{ prediction.lowerBound }} - {{ prediction.upperBound }}</small>
                                        {% else %}
                                            <small class="text-muted">N/A</small>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% if consumptionPredictions|length > 0 %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    const ctx = document.getElementById('consumptionChart').getContext('2d');
    
    // Format dates for better display
    function formatDate(dateStr) {
        const date = new Date(dateStr + 'T00:00:00');
        const month = date.toLocaleString('default', { month: 'short' });
        const day = date.getDate();
        return `${day} ${month}`;
    }
    
    const historicalData = {{ historical|json_encode|raw }};
    const predictionData = {{ consumptionPredictions|json_encode|raw }};
    
    const historicalLabels = historicalData.map(d => formatDate(d.date));
    const historicalValues = historicalData.map(d => parseInt(d.quantity) || 0);
    
    const predictionLabels = predictionData.map(d => formatDate(d.date));
    const predictionValues = predictionData.map(d => parseInt(d.predicted) || 0);
    const upperBounds = predictionData.map(d => d.upperBound ? parseInt(d.upperBound) : null);
    const lowerBounds = predictionData.map(d => d.lowerBound ? parseInt(d.lowerBound) : null);
    
    const allLabels = [...historicalLabels, ...predictionLabels];
    const allHistorical = [...historicalValues, ...Array(predictionLabels.length).fill(null)];
    const allPredictions = [...Array(historicalLabels.length).fill(null), ...predictionValues];
    const allUpperBounds = [...Array(historicalLabels.length).fill(null), ...upperBounds];
    const allLowerBounds = [...Array(historicalLabels.length).fill(null), ...lowerBounds];
    
    // Find max value for better Y-axis scaling
    const allValues = [
        ...historicalValues.filter(v => v !== null), 
        ...predictionValues.filter(v => v !== null),
        ...upperBounds.filter(v => v !== null),
        ...lowerBounds.filter(v => v !== null)
    ];
    const maxValue = Math.max(...allValues, 1);
    const yAxisMax = Math.ceil(maxValue * 1.1); // Add 10% padding
    
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: allLabels,
            datasets: [{
                label: 'Historical Consumption',
                data: allHistorical,
                borderColor: 'rgb(75, 192, 192)',
                backgroundColor: 'rgba(75, 192, 192, 0.2)',
                tension: 0.1,
                spanGaps: true,
                pointRadius: 4,
                pointHoverRadius: 6
            }, {
                label: 'Predicted Consumption',
                data: allPredictions,
                borderColor: 'rgb(255, 99, 132)',
                backgroundColor: 'rgba(255, 99, 132, 0.2)',
                borderDash: [5, 5],
                tension: 0.1,
                spanGaps: true,
                pointRadius: 4,
                pointHoverRadius: 6
            }, {
                label: 'Upper Bound',
                data: allUpperBounds,
                borderColor: 'rgba(255, 99, 132, 0.3)',
                backgroundColor: 'rgba(255, 99, 132, 0.1)',
                borderDash: [2, 2],
                pointRadius: 0,
                fill: '+1'
            }, {
                label: 'Lower Bound',
                data: allLowerBounds,
                borderColor: 'rgba(255, 99, 132, 0.3)',
                backgroundColor: 'rgba(255, 99, 132, 0.1)',
                borderDash: [2, 2],
                pointRadius: 0,
                fill: false
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                title: {
                    display: true,
                    text: 'Consumption History and 14-Day Prediction',
                    font: {
                        size: 16,
                        weight: 'bold'
                    }
                },
                legend: {
                    display: true,
                    position: 'top'
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return context.dataset.label + ': ' + (context.parsed.y !== null ? context.parsed.y : 'N/A') + ' units';
                        }
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    max: yAxisMax,
                    ticks: {
                        stepSize: 1,
                        precision: 0,
                        callback: function(value) {
                            return Number.isInteger(value) ? value : '';
                        }
                    },
                    title: {
                        display: true,
                        text: 'Quantity (units)',
                        font: {
                            weight: 'bold'
                        }
                    }
                },
                x: {
                    ticks: {
                        maxRotation: 45,
                        minRotation: 45,
                        autoSkip: true,
                        maxTicksLimit: 15
                    },
                    title: {
                        display: true,
                        text: 'Date',
                        font: {
                            weight: 'bold'
                        }
                    }
                }
            }
        }
    });
</script>
{% endif %}
{% endblock %}









