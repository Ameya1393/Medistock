{% extends 'base.html.twig' %}

{% block title %}Update Stock - {{ drug.name }}{% endblock %}

{% block body %}
<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-pencil-square"></i> Update Stock: {{ drug.name }}</h1>
        <a href="{{ path('app_stock_index') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Stock
        </a>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Current Stock Information</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <th>Drug Name:</th>
                            <td><strong>{{ drug.name }}</strong></td>
                        </tr>
                        <tr>
                            <th>Category:</th>
                            <td>{{ drug.category }}</td>
                        </tr>
                        <tr>
                            <th>Current Stock:</th>
                            <td>
                                <span class="badge {% if drug.isLowStock() %}bg-danger{% else %}bg-success{% endif %} fs-6">
                                    {{ drug.stockQuantity }}
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <th>Threshold:</th>
                            <td>{{ drug.threshold }}</td>
                        </tr>
                        <tr>
                            <th>Status:</th>
                            <td>
                                {% if drug.isLowStock() %}
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-exclamation-triangle"></i> Low Stock
                                    </span>
                                {% else %}
                                    <span class="badge bg-success">In Stock</span>
                                {% endif %}
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Update Stock</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">Action</label>
                            <select name="action" class="form-select" required>
                                <option value="increase">Increase Stock</option>
                                <option value="decrease">Decrease Stock</option>
                                <option value="set">Set Stock Quantity</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Quantity</label>
                            <input type="number" name="quantity" class="form-control" min="1" required>
                            <small class="form-text text-muted">
                                For "Set Stock Quantity", enter the exact amount. For increase/decrease, enter the amount to add/subtract.
                            </small>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Update Stock
                            </button>
                            <a href="{{ path('app_stock_index') }}" class="btn btn-secondary">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}










