{% extends 'base.html.twig' %}

{% block title %}Stock Management{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-box-seam"></i> Stock Management</h1>
        <a href="{{ path('app_drug_index') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Drugs
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Drug Name</th>
                            <th>Category</th>
                            <th>Current Stock</th>
                            <th>Threshold</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for drug in drugs %}
                        <tr class="{% if drug.isLowStock() %}table-warning{% endif %}">
                            <td>{{ drug.id }}</td>
                            <td><strong>{{ drug.name }}</strong></td>
                            <td>{{ drug.category }}</td>
                            <td>
                                <span class="badge {% if drug.isLowStock() %}bg-danger{% else %}bg-success{% endif %} fs-6">
                                    {{ drug.stockQuantity }}
                                </span>
                            </td>
                            <td>{{ drug.threshold }}</td>
                            <td>
                                {% if drug.isLowStock() %}
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-exclamation-triangle"></i> Low Stock
                                    </span>
                                {% else %}
                                    <span class="badge bg-success">In Stock</span>
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('app_stock_update', {'id': drug.id}) }}" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil-square"></i> Update Stock
                                </a>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="bi bi-inbox"></i> No drugs found. <a href="{{ path('app_drug_new') }}">Add a drug first</a>.
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}

