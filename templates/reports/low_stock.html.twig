{% extends 'base.html.twig' %}

{% block title %}Low Stock Report{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-file-earmark-text"></i> Low Stock Report</h1>
        <div>
            <a href="{{ path('app_reports_download_summary') }}" class="btn btn-success me-2">
                <i class="bi bi-download"></i> Download Full Analytics Report (PDF)
            </a>
            <a href="{{ path('app_reports_usage') }}" class="btn btn-info">
                <i class="bi bi-graph-up"></i> Usage Report
            </a>
            <a href="{{ path('app_dashboard') }}" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Low Stock Drugs Report</h5>
        </div>
        <div class="card-body">
            {% if lowStockDrugs|length > 0 %}
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-warning">
                        <tr>
                            <th>ID</th>
                            <th>Drug Name</th>
                            <th>Category</th>
                            <th>Current Stock</th>
                            <th>Threshold</th>
                            <th>Shortage</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for drug in lowStockDrugs %}
                        <tr class="table-warning">
                            <td>{{ drug.id }}</td>
                            <td><strong>{{ drug.name }}</strong></td>
                            <td>{{ drug.category }}</td>
                            <td>
                                <span class="badge bg-danger fs-6">{{ drug.stockQuantity }}</span>
                            </td>
                            <td>{{ drug.threshold }}</td>
                            <td>
                                <span class="badge bg-danger">
                                    {{ drug.threshold - drug.stockQuantity }} units
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-exclamation-triangle"></i> Low Stock
                                </span>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="mt-3">
                <p class="text-muted">
                    <strong>Total Low Stock Items:</strong> {{ lowStockDrugs|length }}
                </p>
            </div>
            {% else %}
            <div class="text-center text-muted py-5">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                <h4 class="mt-3">No Low Stock Items</h4>
                <p>All drugs are above their threshold levels.</p>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}










