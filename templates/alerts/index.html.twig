{% extends 'base.html.twig' %}

{% block title %}Low Stock Alerts{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-exclamation-triangle"></i> Low Stock Alerts</h1>
        <a href="{{ path('app_dashboard') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-warning text-dark shadow-sm">
                <div class="card-body text-center">
                    <h3>{{ lowStockCount }}</h3>
                    <p class="mb-0">Low Stock Items</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white shadow-sm">
                <div class="card-body text-center">
                    <h3>{{ totalDrugs }}</h3>
                    <p class="mb-0">Total Drugs</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white shadow-sm">
                <div class="card-body text-center">
                    <h3>{{ totalDrugs - lowStockCount }}</h3>
                    <p class="mb-0">In Stock</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Drugs Requiring Attention</h5>
        </div>
        <div class="card-body">
            {% if lowStockDrugs|length > 0 %}
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-warning">
                        <tr>
                            <th>ID</th>
                            <th>Drug Name</th>
                            <th>Category</th>
                            <th>Current Stock</th>
                            <th>Threshold</th>
                            <th>Shortage</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for drug in lowStockDrugs %}
                        <tr class="table-warning">
                            <td>{{ drug.id }}</td>
                            <td><strong>{{ drug.name }}</strong></td>
                            <td>{{ drug.category }}</td>
                            <td>
                                <span class="badge bg-danger fs-6">{{ drug.stockQuantity }}</span>
                            </td>
                            <td>{{ drug.threshold }}</td>
                            <td>
                                <span class="badge bg-danger">
                                    {{ drug.threshold - drug.stockQuantity }} units needed
                                </span>
                            </td>
                            <td>
                                <a href="{{ path('app_stock_update', {'id': drug.id}) }}" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil-square"></i> Update Stock
                                </a>
                                <a href="{{ path('app_drug_show', {'id': drug.id}) }}" class="btn btn-sm btn-info">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <div class="text-center text-muted py-5">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                <h4 class="mt-3">All Good!</h4>
                <p>No low stock alerts at this time. All drugs are above their threshold levels.</p>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}










