{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}
    <div class="mb-3">
        {{ form_label(form.name, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.name) }}
        {{ form_errors(form.name) }}
    </div>
    <div class="mb-3">
        {{ form_label(form.category, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.category) }}
        {{ form_errors(form.category) }}
    </div>
    <div class="mb-3">
        {{ form_label(form.threshold, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.threshold) }}
        {{ form_errors(form.threshold) }}
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-primary">{{ button_label|default('Save') }}</button>
        <a href="{{ path('app_drug_index') }}" class="btn btn-secondary">Cancel</a>
    </div>
{{ form_end(form) }}
