{% extends 'base.html.twig' %}

{% block title %}Drug index{% endblock %}

{% block body %}
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Drugs</h1>
            <a href="{{ path('app_drug_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create new
            </a>
        </div>

        {% if drugs|length > 0 %}
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Id</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Stock</th>
                            <th>Threshold</th>
                            <th>Status</th>
                            <th>Created At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for drug in drugs %}
                            <tr class="{% if drug.isLowStock() %}table-warning{% endif %}">
                                <td>{{ drug.id }}</td>
                                <td>{{ drug.name }}</td>
                                <td>{{ drug.category }}</td>
                                <td>
                                    <span class="badge {% if drug.isLowStock() %}bg-danger{% else %}bg-success{% endif %}">
                                        {{ drug.stockQuantity }}
                                    </span>
                                </td>
                                <td>{{ drug.threshold }}</td>
                                <td>
                                    {% if drug.isLowStock() %}
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-exclamation-triangle"></i> Low
                                        </span>
                                    {% else %}
                                        <span class="badge bg-success">OK</span>
                                    {% endif %}
                                </td>
                                <td>{{ drug.createdAt ? drug.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                                <td>
                                    <a href="{{ path('app_drug_show', {'id': drug.id}) }}" class="btn btn-sm btn-info">
                                        <i class="bi bi-eye"></i> Show
                                    </a>
                                    <a href="{{ path('app_drug_edit', {'id': drug.id}) }}" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> No drugs found. <a href="{{ path('app_drug_new') }}">Create the first one</a>.
            </div>
        {% endif %}
    </div>
{% endblock %}
